{
  "rewrites": [
    { "source": "/api/proxy", "destination": "/api/proxy" },
    { "source": "/player", "destination": "/player.html" },
    { "source": "/", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
